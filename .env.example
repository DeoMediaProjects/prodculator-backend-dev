# App
APP_NAME=Prodculator API
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Observability
# LOG_JSON emits structured JSON logs (with per-request X-Request-ID) — set true
# in production for queryable logs; leave false for readable local dev output.
LOG_JSON=false
# Sentry error monitoring — leave SENTRY_DSN empty to disable. Set in production.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
# SENTRY_ENVIRONMENT defaults to APP_ENV when unset
# SENTRY_ENVIRONMENT=production

# Database
DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/prodculator
AUTO_CREATE_DB_SCHEMA=true

# JWT/Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=3600
JWT_REFRESH_TOKEN_EXPIRES_SECONDS=1209600

# Cookie-based auth. When enabled, sign-in/refresh issue the JWT pair as httpOnly
# cookies so the browser never stores tokens in localStorage (XSS-resistant). The
# Bearer header still works for API clients. SECURE must be true in production
# (HTTPS); set false only for local http dev. SAMESITE: lax | strict | none.
# Set DOMAIN (e.g. .prodculator.com) to share the session across subdomains.
AUTH_COOKIE_ENABLED=true
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_DOMAIN=.prodculator.com

# Redis
REDIS_URL=redis://localhost:6379/0

# Rate limiting (SlowAPI). Counters live in Redis so limits are shared across web
# workers and survive restarts. Leave RATE_LIMIT_STORAGE_URI empty to reuse
# REDIS_URL; set "memory://" for single-process local use. Set RATE_LIMIT_ENABLED
# false to disable. NOTE: run uvicorn with `--proxy-headers --forwarded-allow-ips=*`
# behind a reverse proxy so per-client limits use the real client IP.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URI=

# Durable background-job queue (RQ over Redis) for report generation.
# When true, paid/b2b reports are enqueued and processed by a separate worker
# (`python -m app.worker`) — surviving web restarts. When false (default),
# generation runs in-process via FastAPI BackgroundTasks (fine for local dev).
# Set true in production and run at least one worker process.
REPORT_QUEUE_ENABLED=false
REPORT_QUEUE_JOB_TIMEOUT=1800

# Local object storage (dev fallback — only used when AWS creds are not set)
STORAGE_ROOT=./storage

# AWS S3 (report PDF storage)
# Scripts are never stored — only generated PDFs are uploaded.
# The DB stores the S3 object key; presigned URLs are generated fresh on each request.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION=eu-west-1
AWS_S3_BUCKET_NAME=prodculator-reports
AWS_S3_REPORTS_PREFIX=reports
AWS_S3_PRESIGNED_URL_EXPIRY=900

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Legacy one-time prices
STRIPE_PRICE_SINGLE_USD=price_1Sx84yLcLlewla5EUHVXBQY
STRIPE_PRICE_SINGLE_GBP=price_1Sx5T8LcLlewla5EsQOLFBoy

# Professional monthly ($61 USD / £49 GBP)
STRIPE_PRICE_PROFESSIONAL_USD=
STRIPE_PRICE_PROFESSIONAL_GBP=

# Producer monthly ($149 USD / £119 GBP)
STRIPE_PRICE_PRODUCER_USD=
STRIPE_PRICE_PRODUCER_GBP=

# Studio monthly ($299 USD / £239 GBP)
STRIPE_PRICE_STUDIO_USD=price_1Sx8AfLcLlewla5Exif5R15n
STRIPE_PRICE_STUDIO_GBP=price_1Sx8CpLcLlewla5E42HQTVmg

# Annual plans (GBP only for now — £39/mo, £95/mo, £199/mo billed yearly)
STRIPE_PRICE_PROFESSIONAL_ANNUAL_GBP=
STRIPE_PRICE_PRODUCER_ANNUAL_GBP=
STRIPE_PRICE_STUDIO_ANNUAL_GBP=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# claude-opus-4-8 is the most capable; use claude-sonnet-4-6 for lower cost/latency.
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=8000
ANTHROPIC_ANALYSIS_TIMEOUT=120
ANTHROPIC_MAX_TOKENS_SCRIPT_CHUNK=1500
ANTHROPIC_MAX_TOKENS_SCRIPT_AGGREGATE=3000
ANTHROPIC_MAX_TOKENS_REPORT=7000
ANTHROPIC_TIMEOUT_SCRIPT_CHUNK=120
ANTHROPIC_TIMEOUT_SCRIPT_AGGREGATE=150
ANTHROPIC_TIMEOUT_REPORT=180
SCRIPT_ANALYSIS_CHUNKED_ENABLED=false
SCRIPT_CHUNK_TARGET_TOKENS=1800
SCRIPT_CHUNK_OVERLAP_TOKENS=200
SCRIPT_MAX_CHUNKS=80

# OpenAI (legacy; unused by current script analysis flow)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2000

# Brevo (transactional email)
BREVO_API_KEY=xkeysib-...
BREVO_FROM_EMAIL=noreply@prodculator.com
BREVO_FROM_NAME=Prodculator
CONTACT_EMAIL=support@prodculator.com

# Google Maps
GOOGLE_MAPS_API_KEY=

# TMDB
TMDB_API_KEY=

# Exchange Rate
EXCHANGE_RATE_API_KEY=

# BLS
BLS_API_KEY=

# Grantify
GRANTIFY_API_KEY=
GRANTIFY_AFFILIATE_ID=

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# Docker Compose (optional overrides)
BACKEND_PORT=8001
POSTGRES_DB=prodculator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
REDIS_PORT=6379
