# App
APP_NAME=Prodculator API
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Database
DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/prodculator
AUTO_CREATE_DB_SCHEMA=true

# JWT/Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=3600
JWT_REFRESH_TOKEN_EXPIRES_SECONDS=1209600

# Redis
REDIS_URL=redis://localhost:6379/0

# Local object storage
STORAGE_ROOT=./storage

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SINGLE_USD=price_1Sx84yLcLlewla5EUHVXBQY
STRIPE_PRICE_SINGLE_GBP=price_1Sx5T8LcLlewla5EsQOLFBoy
STRIPE_PRICE_STUDIO_USD=price_1Sx8AfLcLlewla5Exif5R15n
STRIPE_PRICE_STUDIO_GBP=price_1Sx8CpLcLlewla5E42HQTVmg

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2000

# SendGrid
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@prodculator.com

# Google Maps
GOOGLE_MAPS_API_KEY=

# TMDB
TMDB_API_KEY=

# Exchange Rate
EXCHANGE_RATE_API_KEY=

# BLS
BLS_API_KEY=

# Grantify
GRANTIFY_API_KEY=
GRANTIFY_AFFILIATE_ID=

# CORS
CORS_ORIGINS=["http://localhost:5173"]
